{
  "name": "p2p-onelink",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace=apps/api run start:dev",
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:vendor": "npm --workspace=apps/vendor-portal run dev",
    "build:all": "npm run build --workspaces"
  }
}
